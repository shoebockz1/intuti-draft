# Copy this file to .env and fill in real values. .env is git-ignored.

# From https://developer.yahoo.com/apps/ -> Intuti Draft Tool
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# Must exactly match the Redirect URI registered on the Yahoo app
YAHOO_REDIRECT_URI=https://localhost:4000/api/yahoo/callback

# Your league (from HANDOFF.md)
YAHOO_LEAGUE_ID=101893

# A random long string used to sign the local session cookie that holds the
# Yahoo OAuth tokens after login. Any random string is fine for local dev.
SESSION_SECRET=

# Shared passcode for commissioner-only access (Draft Order / Protected
# Players / Order Randomizer tabs, Start Draft, Undo, Reset). Trusted friend
# group — a single shared secret, not per-user accounts. Leave unset to
# disable commissioner login entirely (no default is assumed).
COMMISSIONER_PASSCODE=
