{
  "name": "intuti-server",
  "version": "0.1.0",
  "private": true,
  "description": "Intuti draft tool backend — currently a skeleton with a health-check route. Future home of Sleeper API proxying (and possibly Yahoo OAuth import).",
  "main": "dist/index.js",
  "scripts": {
    "predev": "node ../scripts/generate-version.mjs server/src/version.ts",
    "dev": "tsx watch src/index.ts",
    "prebuild": "node ../scripts/generate-version.mjs server/src/version.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretypecheck": "node ../scripts/generate-version.mjs server/src/version.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-session": "^1.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
